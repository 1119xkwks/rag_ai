# RAG AI Backend - 환경 변수 예시
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채워 사용하세요.

# Qdrant (로컬: localhost + NodePort 30633 / 클러스터 내부: qdrant, 6333)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# OpenAI API 키 (임베딩/LLM용, 필수)
OPENAI_API_KEY=sk-...

# (선택) 임베딩 모델 변경 시
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# (선택) 청크 크기/겹침
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
