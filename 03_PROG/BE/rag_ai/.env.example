# RAG AI Backend - 환경 변수 예시
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채워 사용하세요.

# Qdrant (로컬: localhost + NodePort 30633 / 클러스터 내부: qdrant, 6333)
QDRANT_HOST=127.0.0.1
QDRANT_PORT=30633

# OpenAI API 키 (임베딩/LLM용, 필수)
OPENAI_API_KEY=sk-...

# Gemini API 키 (Google AI Studio 발급)
# GEMINI_API_KEY=AIza...

# (선택) 임베딩 모델 변경 시
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# (선택) 청크 크기/겹침
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50

# ----- LLM Provider 선택 -----
# RAG 답변 생성에 사용할 LLM 백엔드
# - openai : OpenAI Chat API (기본값)
# - vllm   : 회사 내부 vLLM(OpenAI 호환) 서버
# - gemini : Gemini API
# LLM_PROVIDER=vllm

# ----- Embedding Provider 선택 -----
# 질문/문서 임베딩 생성에 사용할 백엔드
# - openai : OpenAI Embeddings API (기본값)
# - vllm   : 회사 내부 vLLM(OpenAI 호환) 서버
# - gemini : Gemini Embeddings API (권장: gemini-embedding-001)
# EMBEDDING_PROVIDER=gemini

# vLLM 서버 설정 (llm_provider=vllm 일 때 사용)
# VLLM_API_URL=http://192.168.1.111:8000/v1
# VLLM_API_KEY=EMPTY
# VLLM_MODEL_NAME=vllm
# VLLM_EMBEDDING_MODEL=vllm

# Gemini 모델 설정
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# API timeout (초)
# OPENAI_TIMEOUT_SEC=60
# VLLM_TIMEOUT_SEC=120
# GEMINI_TIMEOUT_SEC=120

# cleanup 시 원문이 이 글자 수를 넘으면 Gemini Files API로 첨부 (0=항상 인라인)
# GEMINI_CLEANUP_FILE_THRESHOLD_CHARS=30000
# cleanup 시 Gemini 최대 출력 토큰 수
# GEMINI_CLEANUP_MAX_OUTPUT_TOKENS=4096

# Logging
# LOG_LEVEL=DEBUG
# SLOW_REQUEST_MS=3000

# 문서 인입 시 LLM 정제 기본 provider (선택)
# CLEANUP_PROVIDER=gemini

# PDF 텍스트 추출 방식 (기본: pypdf, 옵션: vision_qwen)
# PDF_EXTRACT_METHOD=pypdf

# vision_qwen 옵션 (Qwen-VL + PDF 이미지 OCR)
# QWEN_VL_MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct
# QWEN_VL_MAX_PAGES=20
# QWEN_VL_DPI=160
# QWEN_VL_MAX_NEW_TOKENS=1024
